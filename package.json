{
  "name": "orchid-pagination",
  "type": "module",
  "version": "1.0.0",
  "packageManager": "bun@1.3.14",
  "description": "Orchid ORM query pagination helpers",
  "author": "Ilya Semenov",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/IlyaSemenov/orchid-pagination"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "imports": {
    "#testing": "./testing/index.ts"
  },
  "main": "dist/index.cjs",
  "types": "dist/index.d.ts",
  "files": [
    "!src/**/*.test.*",
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup",
    "lint": "eslint --fix .",
    "prepare": "husky",
    "prepublishOnly": "bun run build",
    "types": "tsgo"
  },
  "peerDependencies": {
    "@types/node": ">=18",
    "orchid-orm": "^1.38.5"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.10",
    "@ilyasemenov/eslint-config": "^1.0.1",
    "@tsconfig/bun": "^1.0.10",
    "@types/bun": "1.3.14",
    "@types/node": "^22.10.1",
    "@typescript/native-preview": "^7.0.0-dev.20260605.1",
    "eslint": "^9.15.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10",
    "orchid-orm": "1.38.5",
    "tsup": "^8.3.5",
    "typescript": "^6.0.3"
  }
}
